## ===========================================
## MQTT - broker en Railway (ya configurado)
## ===========================================
MQTT_URL=mqtt://maglev.proxy.rlwy.net:36922
MQTT_USERNAME=announcer
MQTT_PASSWORD=changeme

## ===========================================
## OAuth2 Google - lo creas vos en Google Cloud Console
## ===========================================
## Ver GMAIL_OAUTH_SETUP.md para los pasos
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

## ===========================================
## OAuth2 Microsoft - Outlook/Hotmail/Live/Office365 (1 clic, sin contraseña)
## ===========================================
## Registrar app en Azure Portal > App registrations. Permiso delegado:
## Office 365 Exchange Online > IMAP.AccessAsUser.All (+ offline_access, openid, email)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/auth/microsoft/callback
## 'common' = cuentas personales + trabajo | 'consumers' = solo personales
MICROSOFT_TENANT=common

## ===========================================
## Encriptacion de refresh_tokens
## ===========================================
## Generar con: openssl rand -base64 32
ENCRYPTION_KEY=base64key32bytes==

## ===========================================
## HTTP server
## ===========================================
HTTP_PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

## ===========================================
## Speaker / IMAP
## ===========================================
SPEAKER_DEVICE_ID=spkr-001
DB_PATH=./_data/db.sqlite

## Allowlist (csv) - opcional, vacio acepta cualquier remitente con parser
ALLOWED_SENDERS=

## ===========================================
## Checkout Wompi (Bancolombia) - sandbox primero (pub_test_/prv_test_)
## ===========================================
WOMPI_PUBLIC_KEY=pub_test_xxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxx
## URL del Web Checkout (no cambiar salvo que Wompi lo indique)
WOMPI_CHECKOUT_URL=https://checkout.wompi.co/p/
## API REST de Wompi. Sandbox: https://sandbox.wompi.co/v1 | Prod: https://production.wompi.co/v1
WOMPI_API_BASE=https://sandbox.wompi.co/v1
## Precio en centavos COP (189.000 COP = 18900000)
PRICE_COP_CENTS=18900000

## ===========================================
## Checkout MercadoPago (Suscripciones / preapproval anual)
## ===========================================
## TEST-... para pruebas (sin dinero real) | APP_USR-... para producción.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

## ===========================================
## Frontend (sono-web) - para redirects del wizard tras OAuth/pago
## ===========================================
FRONTEND_BASE_URL=http://localhost:3001

## ===========================================
## Admin (fulfillment / inventario de devices)
## ===========================================
## Bearer token para /admin/* . Generar con: openssl rand -hex 24
ADMIN_TOKEN=

## ===========================================
## Skydropx (envíos / guías de paquetería)
## ===========================================
## OAuth2 client_credentials del panel pro.skydropx.com. Host api-pro.skydropx.com.
SKYDROPX_CLIENT_ID=
SKYDROPX_CLIENT_SECRET=
## Origen del despacho (bodega). Colombia: DANE = código de 5 dígitos (Medellín = 05001).
SKYDROPX_ORIGIN_DANE=05001
SKYDROPX_ORIGIN_DEPTO=Antioquia
SKYDROPX_ORIGIN_CITY=Medellin
SKYDROPX_ORIGIN_NAME=Sono
SKYDROPX_ORIGIN_STREET=
SKYDROPX_ORIGIN_POSTAL=050001
SKYDROPX_ORIGIN_PHONE=
SKYDROPX_ORIGIN_EMAIL=hola@sono.lat

LOG_LEVEL=info
